<% content_for :title, @course.name %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← Cursos", admin_courses_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-bold text-gray-800"><%= @course.name %></h1>
  <span class="text-sm text-gray-500"><%= @course.study_plan.name %> · <%= @course.academic_year %></span>
  <%= link_to "Editar", edit_admin_course_path(@course), class: "ml-auto text-sm text-indigo-600 hover:underline" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <%# Materias del curso %>
  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-semibold text-gray-700 mb-3">Materias del curso</h2>
    <%= form_with url: assign_subjects_admin_course_path(@course), method: :post, class: "space-y-3" do |f| %>
      <% @course.study_plan.subjects.order(:name).each do |subject| %>
        <label class="flex items-center gap-2 text-sm">
          <%= check_box_tag "subject_ids[]", subject.id,
                @course.subjects.include?(subject),
                class: "h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
          <%= subject.name %>
        </label>
      <% end %>
      <button type="submit" class="mt-3 px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">
        Guardar materias
      </button>
    <% end %>
  </div>

  <%# Docentes asignados %>
  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-semibold text-gray-700 mb-3">Docentes asignados</h2>
    <% if @teacher_assignments.any? %>
      <ul class="space-y-2 mb-4">
        <% @teacher_assignments.each do |ta| %>
          <li class="flex items-center justify-between text-sm">
            <div>
              <span class="font-medium"><%= ta.user.full_name %></span>
              <span class="text-gray-400 ml-2 text-xs">→ <%= ta.course_subject.subject.name %></span>
            </div>
            <%= button_to "Desvincular",
                  admin_course_teacher_assignment_path(@course, ta), method: :delete,
                  data: { turbo_confirm: "¿Desvincular a #{ta.user.display_name}?" },
                  class: "text-xs text-red-500 hover:text-red-700" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-400 mb-4">Sin docentes asignados.</p>
    <% end %>

    <h3 class="text-sm font-medium text-gray-600 mb-2">Asignar docente</h3>
    <%= form_with url: admin_course_teacher_assignments_path(@course), method: :post, class: "space-y-2" do |f| %>
      <select name="teacher_assignment[course_subject_id]"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <option value="">Materia…</option>
        <% @course_subjects.each do |cs| %>
          <option value="<%= cs.id %>"><%= cs.subject.name %></option>
        <% end %>
      </select>
      <select name="teacher_assignment[user_id]"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <option value="">Docente…</option>
        <% @available_teachers.each do |t| %>
          <option value="<%= t.id %>"><%= t.full_name %></option>
        <% end %>
      </select>
      <input type="hidden" name="teacher_assignment[academic_year]" value="<%= @course.academic_year %>">
      <button type="submit" class="px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">
        Asignar
      </button>
    <% end %>
  </div>
</div>
