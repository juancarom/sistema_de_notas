<% content_for :title, "Editar materia del plan" %>
<div class="mb-6">
  <%= link_to "← #{@study_plan_subject.study_plan.name}", admin_study_plan_path(@study_plan_subject.study_plan),
        class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-bold text-gray-800 mt-1">Editar materia del plan</h1>
</div>
<div class="bg-white rounded-xl shadow p-6 max-w-md">
  <%= simple_form_for @study_plan_subject, url: admin_study_plan_subject_path(@study_plan_subject), method: :patch do |f| %>
    <%= f.error_notification %>
    <%= f.input :subject_id, label: "Materia", as: :select,
          collection: @available_subjects.map { |s| [s.name, s.id] } %>
    <%= f.input :year_in_plan, label: "Año en el plan", as: :integer %>
    <div class="flex gap-3 mt-4">
      <%= f.button :submit, "Guardar cambios" %>
      <%= link_to "Cancelar", admin_study_plan_path(@study_plan_subject.study_plan),
            class: "px-4 py-2 text-sm text-gray-600" %>
    </div>
  <% end %>
</div>
