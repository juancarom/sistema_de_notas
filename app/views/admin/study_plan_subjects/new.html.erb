<% content_for :title, "Agregar materia al plan" %>
<div class="mb-6">
  <%= link_to "← #{@study_plan.name}", admin_study_plan_path(@study_plan), class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-bold text-gray-800 mt-1">Agregar materia al plan</h1>
</div>
<div class="bg-white rounded-xl shadow p-6 max-w-md">
  <%= simple_form_for @study_plan_subject, url: admin_study_plan_study_plan_subjects_path(@study_plan) do |f| %>
    <%= f.error_notification %>
    <%= f.hidden_field :study_plan_id %>
    <%= f.input :subject_id, label: "Materia", as: :select,
          collection: @available_subjects.map { |s| [s.name, s.id] },
          include_blank: "Seleccioná una materia" %>
    <%= f.input :year_in_plan, label: "Año en el plan", as: :integer,
          hint: "1 = primer año, 2 = segundo año, etc." %>
    <div class="flex gap-3 mt-4">
      <%= f.button :submit, "Agregar materia" %>
      <%= link_to "Cancelar", admin_study_plan_path(@study_plan), class: "px-4 py-2 text-sm text-gray-600" %>
    </div>
  <% end %>
</div>
