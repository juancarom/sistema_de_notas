<% content_for :title, "#{@user.full_name} — Usuarios" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← Usuarios", admin_users_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-bold text-gray-800"><%= @user.full_name %></h1>
  <span class="text-sm text-gray-500"><%= @user.email %></span>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-semibold text-gray-700 mb-3">Datos personales</h2>
    <dl class="space-y-2 text-sm">
      <% [["DNI", @user.dni], ["Teléfono", @user.phone], ["Dirección", @user.address], ["Ciudad", @user.city]].each do |label, val| %>
        <% if val.present? %>
          <div class="flex gap-2"><dt class="text-gray-500 w-24"><%= label %></dt><dd class="text-gray-800"><%= val %></dd></div>
        <% end %>
      <% end %>
    </dl>
    <div class="mt-4">
      <%= link_to "Editar datos", edit_admin_user_path(@user), class: "text-sm text-indigo-600 hover:underline" %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-semibold text-gray-700 mb-3">Roles en <%= current_school.name %></h2>
    <% if @roles.any? %>
      <ul class="space-y-2 mb-4">
        <% @roles.each do |urs| %>
          <li class="flex items-center justify-between text-sm">
            <div>
              <span class="font-medium"><%= UserRoleSchool::ROLE_LABELS[urs.role] %></span>
              <span class="text-gray-400 ml-2">desde <%= urs.valid_from&.strftime("%d/%m/%Y") %></span>
              <% if urs.valid_until %>
                <span class="text-gray-400">hasta <%= urs.valid_until.strftime("%d/%m/%Y") %></span>
              <% end %>
            </div>
            <%= button_to "Quitar", admin_user_remove_role_path(@user, role: urs.role),
                  method: :delete, data: { turbo_confirm: "¿Quitar el rol #{UserRoleSchool::ROLE_LABELS[urs.role]}?" },
                  class: "text-xs text-red-500 hover:text-red-700" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-400 mb-4">Sin roles asignados.</p>
    <% end %>

    <h3 class="text-sm font-medium text-gray-600 mb-2">Asignar rol</h3>
    <%= form_with url: assign_role_admin_user_path(@user), method: :post, class: "flex gap-2" do |f| %>
      <%= f.select :role, UserRoleSchool.roles.keys.map { |r| [UserRoleSchool::ROLE_LABELS[r], r] },
            { prompt: "Seleccioná un rol" },
            class: "flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm" %>
      <%= f.submit "Asignar", class: "px-3 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700" %>
    <% end %>
  </div>
</div>
