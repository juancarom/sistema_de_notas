<% content_for :title, "Usuarios — #{current_school.name}" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Usuarios y Roles</h1>
  <%= link_to "Nuevo usuario", new_admin_user_path, class: "btn-primary" %>
</div>

<%= form_with url: admin_users_path, method: :get, class: "mb-4 flex gap-2" do |f| %>
  <%= f.text_field :q, value: params[:q], placeholder: "Buscar por nombre, apellido o email…",
        class: "px-3 py-2 border border-gray-300 rounded-lg text-sm w-72 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
  <%= f.submit "Buscar", class: "px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm rounded-lg" %>
<% end %>

<div class="bg-white rounded-xl shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Nombre</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Email</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Roles</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @users.each do |user| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-gray-800"><%= user.full_name %></td>
          <td class="px-4 py-3 text-gray-600"><%= user.email %></td>
          <td class="px-4 py-3">
            <% user.user_role_schools.select { |urs| urs.school_id == current_school.id }.each do |urs| %>
              <span class="inline-block text-xs bg-indigo-100 text-indigo-700 px-2 py-0.5 rounded mr-1">
                <%= UserRoleSchool::ROLE_LABELS[urs.role] %>
              </span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-right">
            <%= link_to "Ver", admin_user_path(user), class: "text-indigo-600 hover:underline text-xs mr-2" %>
            <%= link_to "Editar", edit_admin_user_path(user), class: "text-gray-600 hover:underline text-xs" %>
          </td>
        </tr>
      <% end %>
      <% if @users.empty? %>
        <tr><td colspan="4" class="px-4 py-6 text-center text-gray-400">Sin resultados.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
