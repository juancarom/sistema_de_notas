<% content_for :title, "Planes de Estudio" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Planes de Estudio</h1>
  <%= link_to "Nuevo plan", new_admin_study_plan_path, class: "btn-primary" %>
</div>

<div class="bg-white rounded-xl shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Nombre</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Nivel</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Tipo</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Duración</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @study_plans.each do |plan| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-gray-800"><%= plan.name %></td>
          <td class="px-4 py-3 text-gray-600"><%= plan.level_label %></td>
          <td class="px-4 py-3 text-gray-600"><%= plan.plan_type %></td>
          <td class="px-4 py-3 text-gray-600"><%= plan.duration_years %> año<%= plan.duration_years == 1 ? "" : "s" %></td>
          <td class="px-4 py-3">
            <span class="text-xs px-2 py-0.5 rounded-full <%= plan.active? ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
              <%= plan.active? ? "Activo" : "Inactivo" %>
            </span>
          </td>
          <td class="px-4 py-3 text-right space-x-2">
            <%= link_to "Ver", admin_study_plan_path(plan), class: "text-indigo-600 hover:underline text-xs" %>
            <%= link_to "Editar", edit_admin_study_plan_path(plan), class: "text-gray-600 hover:underline text-xs" %>
          </td>
        </tr>
      <% end %>
      <% if @study_plans.empty? %>
        <tr><td colspan="6" class="px-4 py-6 text-center text-gray-400">No hay planes de estudio creados.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
