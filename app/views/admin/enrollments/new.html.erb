<% content_for :title, "Nueva matrícula" %>
<div class="mb-6">
  <%= link_to "← Matrículas", admin_enrollments_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-bold text-gray-800 mt-1">Nueva matrícula</h1>
</div>
<div class="bg-white rounded-xl shadow p-6 max-w-lg">
  <%= simple_form_for @enrollment, url: admin_enrollments_path do |f| %>
    <%= f.error_notification %>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Alumno</label>
      <select name="enrollment[user_id]"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <option value="">Seleccioná un alumno</option>
        <% @users_for_select.each do |u| %>
          <option value="<%= u.id %>"><%= u.full_name %> (<%= u.email %>)</option>
        <% end %>
      </select>
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Curso</label>
      <select name="enrollment[course_id]"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <option value="">Sin curso (terciario — selección individual)</option>
        <% @courses.each do |c| %>
          <option value="<%= c.id %>"><%= c.name %> — <%= c.study_plan.name %> (<%= c.academic_year %>)</option>
        <% end %>
      </select>
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Ciclo lectivo</label>
      <input type="number" name="enrollment[academic_year]" value="<%= Date.today.year %>"
             class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
    </div>
    <div class="flex gap-3 mt-4">
      <button type="submit" class="py-2 px-4 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg text-sm">
        Matricular
      </button>
      <%= link_to "Cancelar", admin_enrollments_path, class: "px-4 py-2 text-sm text-gray-600" %>
    </div>
  <% end %>
</div>
