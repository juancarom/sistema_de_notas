<% content_for :title, "Editar matrícula" %>
<div class="mb-6">
  <%= link_to "← #{@enrollment.user.full_name}", admin_enrollment_path(@enrollment), class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-bold text-gray-800 mt-1">Editar matrícula</h1>
</div>
<div class="bg-white rounded-xl shadow p-6 max-w-lg">
  <%= simple_form_for @enrollment, url: admin_enrollment_path(@enrollment), method: :patch do |f| %>
    <%= f.error_notification %>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Curso</label>
      <select name="enrollment[course_id]"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <option value="">Sin curso</option>
        <% @courses.each do |c| %>
          <option value="<%= c.id %>" <%= @enrollment.course_id == c.id ? 'selected' : '' %>>
            <%= c.name %> — <%= c.study_plan.name %> (<%= c.academic_year %>)
          </option>
        <% end %>
      </select>
    </div>
    <%= f.input :status, label: "Estado", as: :select,
          collection: Enrollment.statuses.keys.map { |s| [{ "active" => "Activo", "graduated" => "Egresado", "withdrawn" => "Baja" }[s], s] } %>
    <div class="flex gap-3 mt-4">
      <%= f.button :submit, "Guardar cambios" %>
      <%= link_to "Cancelar", admin_enrollment_path(@enrollment), class: "px-4 py-2 text-sm text-gray-600" %>
    </div>
  <% end %>
</div>
