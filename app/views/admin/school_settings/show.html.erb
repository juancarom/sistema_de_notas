<% content_for :title, "Configuración — #{current_school.name}" %>
<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Configuración de la Institución</h1>
  <%= link_to "Editar", edit_admin_school_settings_path, class: "btn-primary" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-semibold text-gray-700 mb-3">Datos generales</h2>
    <dl class="space-y-2 text-sm">
      <% [["Nombre", @school.name], ["Ciudad", @school.city], ["Provincia", @school.province],
          ["Dirección", @school.address], ["C.P.", @school.postal_code],
          ["Teléfono", @school.phone], ["Email", @school.contact_email],
          ["Web", @school.website]].each do |label, val| %>
        <% if val.present? %>
          <div class="flex gap-2"><dt class="text-gray-500 w-28"><%= label %></dt><dd class="text-gray-800"><%= val %></dd></div>
        <% end %>
      <% end %>
    </dl>
  </div>

  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-semibold text-gray-700 mb-3">Escala de notas</h2>
    <dl class="space-y-2 text-sm">
      <div class="flex gap-2"><dt class="text-gray-500 w-28">Mínima</dt><dd><%= @school.min_grade %></dd></div>
      <div class="flex gap-2"><dt class="text-gray-500 w-28">Máxima</dt><dd><%= @school.max_grade %></dd></div>
      <div class="flex gap-2"><dt class="text-gray-500 w-28">Aprobación</dt><dd><%= @school.passing_grade %></dd></div>
    </dl>
    <% if @school.logo.attached? %>
      <div class="mt-4">
        <p class="text-xs text-gray-500 mb-1">Logo</p>
        <%= image_tag @school.logo.variant(resize_to_limit: [200, 80]) %>
      </div>
    <% end %>
  </div>
</div>
