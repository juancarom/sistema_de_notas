<% content_for :title, "Analítico #{@transcript.academic_year} — #{@student.full_name}" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← Analíticos", students_transcripts_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-bold text-gray-800">Analítico <%= @transcript.academic_year %></h1>
  <span class="text-sm text-gray-500"><%= @student.full_name %></span>
  <% if @enrollment.course %>
    <span class="text-sm text-gray-400">· <%= @enrollment.course.name %></span>
  <% end %>
  <% if @transcript.locked? %>
    <span class="ml-auto text-xs bg-red-100 text-red-600 px-2 py-1 rounded">Cerrado</span>
  <% end %>
</div>

<% if @subjects.empty? %>
  <div class="bg-white rounded-xl shadow p-8 text-center text-gray-400">
    Sin materias inscriptas.
  </div>
<% elsif @grading_instances.empty? %>
  <div class="bg-white rounded-xl shadow p-8 text-center text-gray-400">
    Sin instancias de notas configuradas para este ciclo.
  </div>
<% else %>
  <div class="bg-white rounded-xl shadow overflow-x-auto">
    <table class="text-sm w-full">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 font-medium text-gray-600 sticky left-0 bg-gray-50 min-w-[200px]">Materia</th>
          <% @grading_instances.each do |gi| %>
            <th class="text-center px-4 py-3 font-medium text-gray-600 min-w-[120px]">
              <%= gi.name %>
              <% if gi.is_final? %>
                <span class="block text-xs font-normal text-yellow-600">Final</span>
              <% end %>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @subjects.each do |subject| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium text-gray-800 sticky left-0 bg-white"><%= subject.name %></td>
            <% @grading_instances.each do |gi| %>
              <% grade = @grades_map[[subject.id, gi.id]] %>
              <td class="px-4 py-3 text-center">
                <% if grade %>
                  <span class="font-semibold <%= grade.approved? ? 'text-green-600' : (grade.value.present? ? 'text-red-600' : 'text-gray-400') %>">
                    <%= grade.value %>
                  </span>
                  <% if gi.is_final? && grade.approved? %>
                    <span class="block text-xs text-green-500">Aprobado</span>
                  <% elsif gi.is_final? && grade.value.present? %>
                    <span class="block text-xs text-red-500">Desaprobado</span>
                  <% end %>
                <% else %>
                  <span class="text-gray-300">—</span>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
