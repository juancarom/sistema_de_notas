<% content_for :title, "Inicio — #{current_school.name}" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Bienvenido/a, <%= current_user.display_name %></h1>
  <p class="text-gray-500 mt-1"><%= current_school.name %></p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  <% if current_user_has_role?(:admin, :principal, :student_office) %>
    <%= link_to admin_study_plans_path, class: "bg-white rounded-lg shadow p-5 hover:shadow-md transition" do %>
      <div class="text-blue-600 font-semibold mb-1">Planes de Estudio</div>
      <p class="text-sm text-gray-500">Gestionar planes, materias y cursos</p>
    <% end %>

    <%= link_to admin_users_path, class: "bg-white rounded-lg shadow p-5 hover:shadow-md transition" do %>
      <div class="text-blue-600 font-semibold mb-1">Personas y Roles</div>
      <p class="text-sm text-gray-500">Gestionar usuarios de la institución</p>
    <% end %>

    <%= link_to admin_enrollments_path, class: "bg-white rounded-lg shadow p-5 hover:shadow-md transition" do %>
      <div class="text-blue-600 font-semibold mb-1">Matrículas</div>
      <p class="text-sm text-gray-500">Inscribir y gestionar alumnos</p>
    <% end %>
  <% end %>

  <% if current_user_has_role?(:teacher) %>
    <%= link_to teachers_courses_path, class: "bg-white rounded-lg shadow p-5 hover:shadow-md transition" do %>
      <div class="text-green-600 font-semibold mb-1">Mis Cursos</div>
      <p class="text-sm text-gray-500">Cargar notas en mis materias</p>
    <% end %>
  <% end %>

  <% if current_user_has_role?(:student) %>
    <%= link_to students_transcripts_path, class: "bg-white rounded-lg shadow p-5 hover:shadow-md transition" do %>
      <div class="text-purple-600 font-semibold mb-1">Mi Analítico</div>
      <p class="text-sm text-gray-500">Ver mis notas</p>
    <% end %>
  <% end %>

  <% if current_user_has_role?(:proctor) %>
    <%= link_to admin_enrollments_path, class: "bg-white rounded-lg shadow p-5 hover:shadow-md transition" do %>
      <div class="text-yellow-600 font-semibold mb-1">Alumnos</div>
      <p class="text-sm text-gray-500">Ver lista de alumnos</p>
    <% end %>
  <% end %>
</div>
