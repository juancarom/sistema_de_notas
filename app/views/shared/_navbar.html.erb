<nav class="bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">
    <div class="flex items-center gap-3">
      <% if current_school&.logo&.attached? %>
        <%= image_tag current_school.logo.variant(resize_to_limit: [120, 40]), class: "h-10 object-contain" %>
      <% else %>
        <span class="font-bold text-gray-800 text-lg"><%= current_school&.name %></span>
      <% end %>
    </div>

    <% if user_signed_in? %>
      <div class="flex items-center gap-4">
        <span class="text-sm text-gray-600"><%= current_user.display_name %></span>
        <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">
          <%= current_user_roles.map { |r| UserRoleSchool::ROLE_LABELS[r] }.join(", ") %>
        </span>
        <%= button_to "Salir", destroy_user_session_path, method: :delete,
              class: "text-sm text-gray-500 hover:text-gray-800" %>
      </div>
    <% end %>
  </div>
</nav>
