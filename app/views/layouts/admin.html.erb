<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin — #{current_school&.name}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100">
    <%= render "shared/navbar" %>

    <div class="flex min-h-screen">
      <%# Sidebar %>
      <aside class="w-56 bg-white border-r border-gray-200 pt-4 flex-shrink-0">
        <nav class="flex flex-col gap-0.5 px-2">
          <p class="px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">Gestión</p>

          <%= link_to "Usuarios y Roles", admin_users_path,
                class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 #{controller_name == 'users' && controller.class.name.start_with?('Admin') ? 'bg-indigo-50 text-indigo-700 font-medium' : ''}" %>

          <%= link_to "Planes de Estudio", admin_study_plans_path,
                class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 #{controller_name == 'study_plans' ? 'bg-indigo-50 text-indigo-700 font-medium' : ''}" %>

          <%= link_to "Materias", admin_subjects_path,
                class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 #{controller_name == 'subjects' ? 'bg-indigo-50 text-indigo-700 font-medium' : ''}" %>

          <%= link_to "Cursos", admin_courses_path,
                class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 #{controller_name == 'courses' ? 'bg-indigo-50 text-indigo-700 font-medium' : ''}" %>

          <%= link_to "Instancias de Notas", admin_grading_instances_path,
                class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 #{controller_name == 'grading_instances' ? 'bg-indigo-50 text-indigo-700 font-medium' : ''}" %>

          <%= link_to "Matrículas", admin_enrollments_path,
                class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 #{controller_name == 'enrollments' ? 'bg-indigo-50 text-indigo-700 font-medium' : ''}" %>

          <div class="border-t border-gray-100 my-2"></div>

          <p class="px-3 pt-1 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">Config</p>

          <%= link_to "Configuración", admin_school_settings_path,
                class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 #{controller_name == 'school_settings' ? 'bg-indigo-50 text-indigo-700 font-medium' : ''}" %>
        </nav>
      </aside>

      <%# Main content %>
      <main class="flex-1 px-6 py-6 overflow-auto">
        <% flash.each do |type, message| %>
          <div class="mb-4 p-3 rounded-lg text-sm <%= type == 'alert' ? 'bg-red-100 text-red-700 border border-red-200' : 'bg-green-100 text-green-700 border border-green-200' %>">
            <%= message %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
