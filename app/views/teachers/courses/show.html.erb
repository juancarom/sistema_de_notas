<% content_for :title, @course.name %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← Mis cursos", teachers_courses_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-bold text-gray-800"><%= @course.name %></h1>
  <span class="text-sm text-gray-500"><%= @course.study_plan.name %> · <%= @course.academic_year %></span>
</div>

<div class="bg-white rounded-xl shadow p-5">
  <h2 class="font-semibold text-gray-700 mb-3">Materias asignadas</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
    <% @course_subjects.each do |cs| %>
      <%= link_to grade_sheet_teachers_course_path(@course, subject_id: cs.subject_id),
            class: "border border-gray-200 rounded-lg p-4 hover:bg-indigo-50 hover:border-indigo-300 transition" do %>
        <div class="font-medium text-gray-800"><%= cs.subject.name %></div>
        <div class="text-xs text-indigo-600 mt-1">Abrir planilla →</div>
      <% end %>
    <% end %>
  </div>
</div>
